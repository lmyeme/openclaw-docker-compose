
# DANGEROUS: 启用 Host-header origin fallback 模式  
# 影响：降低安全性，使系统容易受到 DNS 重绑定攻击  
# 安全审计会标记为危险配置 (critical/warn 级别)  
# 仅在明确了解风险且部署环境依赖此行为时使用  
# 替代方案：使用 ALLOWED_ORIGINS 配置明确的允许源列表  
DANGEROUS_ALLOW_HOST_HEADER_FALLBACK=true  

# 网关配置
#OPENCLAW_GATEWAY_PORT=18789
#OPENCLAW_BRIDGE_PORT=18790
#OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN= da19d0c37e71006d93bc376918940dde6706687c446766cf479fdf9a4cc37cf5

# 基础路径
OPENCLAW_CONFIG_DIR=./.openclaw
OPENCLAW_WORKSPACE_DIR=./.openclaw/workspace

# 工作空间配置（不要更改）
#WORKSPACE=/home/node/.openclaw/workspace

# 挂载目录配置（按实际更改）
# OpenClaw 数据目录（包含配置文件、工作空间等所有数据）
#OPENCLAW_DATA_DIR=~/.openclaw


# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json


# Claude 集成（可选）
#CLAUDE_AI_SESSION_KEY=
#CLAUDE_WEB_SESSION_KEY=
#CLAUDE_WEB_COOKIE=
